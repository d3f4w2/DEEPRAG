# =============================================================================
# Deep RAG Configuration File
# =============================================================================

# LLM provider, default=google, optional: openai、google、anthropic、custom、......
API_PROVIDER=openai

# Tool calling mode, default=function, stronger tool calling capabilities, optional: function、react
TOOL_CALLING_MODE=function

# Temperature, default=0, strongest instruction following ability
TEMPERATURE=0

# Maximum output TOKENS, default=8192
MAX_TOKENS=4096

# Knowledge base path, default=./Knowledge-Base
KNOWLEDGE_BASE_PATH=./Knowledge-Base

# Knowledge base chunks path, default=./Knowledge-Base
KNOWLEDGE_BASE_CHUNKS_PATH=./Knowledge-Base

# Knowledge base file summary path, default=./Knowledge-Base-File-Summary/summary.txt
KNOWLEDGE_BASE_FILE_SUMMARY=./Knowledge-Base-File-Summary/summary.txt

# Retrieval guardrails (to control token usage)
MAX_RETRIEVE_FILES=6
MAX_RETRIEVE_CHARS_PER_FILE=4000
MAX_RETRIEVE_TOTAL_CHARS=12000
ALLOW_RETRIEVE_ALL=false
MAX_SECTION_CHARS=1200
MAX_SECTION_TOTAL_CHARS=9000
MAX_SEARCH_TOP_K=10


# =============================================================================
# LLM Provider Configuration (All APIs use OpenAI completions format)
# =============================================================================

# OpenAI GPT
OPENAI_API_KEY=sk-37f15cc8e5b144b2a6b239b184da8844dada8be1ff2f7ffe9314e5ffc7ed69ca
OPENAI_BASE_URL=https://code.rayinai.com/v1
OPENAI_MODEL=gpt-5.4-mini

# Google Gemini
GOOGLE_API_KEY=your_google_key
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
GOOGLE_MODEL=gemini-2.5-flash-lite

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Custom LLM API
CUSTOM_API_KEY=your_api_key
CUSTOM_BASE_URL=https://your-api.com/v1/chat/completions
CUSTOM_MODEL=your-model
CUSTOM_HEADERS={"Authorization":"Bearer token"}


# =============================================================================
# Add New Provider (No code modification needed!)
# =============================================================================
# Just add 3 lines of configuration:
#   PROVIDER_API_KEY=your_key
#   PROVIDER_BASE_URL=https://api.provider.com/v1
#   PROVIDER_MODEL=model-name
# Then set API_PROVIDER=provider
# =============================================================================
